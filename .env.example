# --- App ---
ENVIRONMENT=development
API_V1_PREFIX=/api/v1
PROJECT_NAME=Guidian

# --- Database ---
DATABASE_URL=postgresql+asyncpg://guidian:guidian@postgres:5432/guidian
SYNC_DATABASE_URL=postgresql+psycopg://guidian:guidian@postgres:5432/guidian

# --- Redis / Celery ---
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# --- JWT ---
JWT_SECRET_KEY=change-me-in-prod
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- S3 / MinIO ---
S3_ENDPOINT_URL=http://minio:9000
S3_ACCESS_KEY=guidian
S3_SECRET_KEY=guidian-dev-secret
S3_BUCKET_COURSES=guidian-courses
S3_BUCKET_AUDIO=guidian-audio
S3_BUCKET_CERTIFICATES=guidian-certificates
S3_REGION=us-east-1

# --- AI ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-6
OPENAI_API_KEY=
TTS_PROVIDER=openai
TTS_VOICE=alloy

# --- Web ---
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1
